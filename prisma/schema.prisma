generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  OPERATOR
  USER
}

model User {
  id             String          @id @default(uuid())
  callsign       String          @unique
  email          String          @unique
  name           String
  city           String
  state          String
  role           Role            @default(USER)
  passwordHash   String          @map("password_hash")
  emailVerified  DateTime?       @map("email_verified")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  assignedEvents EventOperator[]

  @@map("users")
}

model Template {
  id         String   @id @default(uuid())
  name       String
  bgImage    Bytes?   @map("bg_image")
  bgMimeType String?  @map("bg_mime_type")
  config     Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  events Event[]

  @@map("templates")
}

model Event {
  id           String    @id @default(uuid())
  name         String
  startDate    DateTime  @map("start_date")
  endDate      DateTime  @map("end_date")
  templateId   String?   @map("template_id")
  observations String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  template  Template?       @relation(fields: [templateId], references: [id])
  qsos      QSO[]
  operators EventOperator[]
  eventBands EventBand[]
  eventModes EventMode[]

  @@map("events")
}

model QSO {
  id                  String   @id @default(uuid())
  eventId             String   @map("event_id")
  participantCallsign String   @map("participant_callsign")
  operatorCallsign    String?  @map("operator_callsign")
  dateTime            DateTime @map("date_time")
  frequency           String
  mode                String
  bandId              String?  @map("band_id")
  modeId              String?  @map("mode_id")
  rstSent             String   @map("rst_sent")
  rstReceived         String   @map("rst_received")
  observations        String?
  createdAt           DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  band  Band?  @relation(fields: [bandId], references: [id])
  modeRef Mode? @relation(fields: [modeId], references: [id])

  @@map("qsos")
}

model EventOperator {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_operators")
}

model PasswordResetToken {
  id      String   @id @default(uuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id      String   @id @default(uuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
  @@map("email_verification_tokens")
}

model Band {
  id        String   @id @default(uuid())
  name      String   @unique
  label     String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  eventBands EventBand[]
  qsos       QSO[]

  @@map("bands")
}

model Mode {
  id        String   @id @default(uuid())
  name      String   @unique
  label     String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  eventModes EventMode[]
  qsos       QSO[]

  @@map("modes")
}

model EventBand {
  id      String @id @default(uuid())
  eventId String @map("event_id")
  bandId  String @map("band_id")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  band  Band  @relation(fields: [bandId], references: [id], onDelete: Cascade)

  @@unique([eventId, bandId])
  @@map("event_bands")
}

model EventMode {
  id      String @id @default(uuid())
  eventId String @map("event_id")
  modeId  String @map("mode_id")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  mode  Mode  @relation(fields: [modeId], references: [id], onDelete: Cascade)

  @@unique([eventId, modeId])
  @@map("event_modes")
}
